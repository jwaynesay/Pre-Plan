# If the site is deployed under a subpath (e.g. GitHub Pages project site), set:
# VITE_BASE_PATH=/your-repo-name/
# Leave unset for apex domain or www at site root (typical Cloudflare).

# --- REQUIRED FOR LIVE SEARCH ON THE PUBLIC WEBSITE (Cloudflare Pages, etc.) ---
# The React app is static; search runs on the Node server in /server. Deploy that API
# (Render, Railway, Fly.io, VPS…) and set its public HTTPS URL here (no trailing slash).
# Example: https://api.pre-plan.org
# Then add the same variable in Cloudflare Pages → Settings → Environment variables
# and trigger a new build (Vite reads this at build time).
# VITE_API_URL=

# Google AdSense / AdMob (web) — Featured section + bottom banner
# Get your client ID and ad unit slots from https://www.google.com/adsense (or AdMob for apps)
# Leave empty to hide live ads.

VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
VITE_ADSENSE_FEATURED_SLOT=xxxxxxxxxx
# Bottom popup banner (optional; falls back to FEATURED_SLOT if not set)
VITE_ADSENSE_BOTTOM_SLOT=xxxxxxxxxx
