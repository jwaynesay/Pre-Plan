# Google AdSense / AdMob (web) — Featured section + bottom banner
# Get your client ID and ad unit slots from https://www.google.com/adsense (or AdMob for apps)
# Leave empty to hide live ads.

VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
VITE_ADSENSE_FEATURED_SLOT=xxxxxxxxxx
# Bottom popup banner (optional; falls back to FEATURED_SLOT if not set)
VITE_ADSENSE_BOTTOM_SLOT=xxxxxxxxxx
