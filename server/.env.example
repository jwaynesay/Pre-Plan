PORT=3001
NODE_ENV=development

# Optional: Google Maps API key for real place search (Places + Geocoding).
# Without this, search and spreading endpoints return mock data.
GOOGLE_MAPS_API_KEY=

# Optional: Contact form email. If set, POST /api/contact sends mail to this address.
# Uses SMTP or Nodemailer transport (see CONTACT_* below).
CONTACT_TO_EMAIL=jwaynesay@gmail.com

# SMTP for contact form (e.g. Gmail app password, SendGrid, Mailgun).
# If not set, contact submissions are logged to server/contact-submissions.json only.
CONTACT_SMTP_HOST=
CONTACT_SMTP_PORT=587
CONTACT_SMTP_SECURE=false
CONTACT_SMTP_USER=
CONTACT_SMTP_PASS=
CONTACT_FROM_EMAIL=Pre-Plan <noreply@example.com>
